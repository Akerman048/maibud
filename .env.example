# Required in every environment. Use a pooled Neon URL in production and keep
# TLS verification enabled.
DATABASE_URL=postgresql://user:password@host/database?sslmode=verify-full
AUTH_SECRET=replace-with-at-least-32-random-characters
AUTH_URL=http://localhost:3000
AUTH_TRUST_HOST=true
APP_URL=http://localhost:3000

# Optional Google authentication. Set both server-only values to enable the
# provider; leaving both empty keeps credentials authentication available.
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# The platform/Dockerfile sets NODE_ENV=production. Do not put NODE_ENV in a
# shared local .env file because Next.js controls it for dev/build/start.
PORT=3000
HOSTNAME=0.0.0.0

# Required for document upload/download. Prefer workload credentials in AWS;
# static keys are required only when no IAM role or workload identity is used.
AWS_REGION=eu-central-1
AWS_S3_BUCKET=replace-with-private-bucket-name
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Required for the email worker. The application build and web process do not
# call Resend; keep the worker disabled until these values are production-ready.
RESEND_API_KEY=re_placeholder
EMAIL_FROM="МайБуд <notifications@example.com>"
EMAIL_JOB_SECRET=replace-with-at-least-32-random-characters

# Optional production tuning. Values are milliseconds unless noted otherwise.
PG_POOL_MAX=5
PG_CONNECTION_TIMEOUT_MS=5000
PG_IDLE_TIMEOUT_MS=30000
PG_QUERY_TIMEOUT_MS=30000
AWS_MAX_ATTEMPTS=3
AWS_CONNECTION_TIMEOUT_MS=3000
AWS_REQUEST_TIMEOUT_MS=30000
AWS_SOCKET_TIMEOUT_MS=30000
MAX_DOCUMENT_FILE_SIZE=26214400

# Optional release metadata and metrics.
APP_VERSION=0.1.0
NEXT_PUBLIC_APP_VERSION=0.1.0
METRICS_LOG_ENABLED=false

# Optional Sentry runtime configuration. Leave both DSNs empty to disable it.
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ENVIRONMENT=production
NEXT_PUBLIC_SENTRY_ENVIRONMENT=production
SENTRY_RELEASE=
NEXT_PUBLIC_SENTRY_RELEASE=

# Build-only Sentry source-map upload credentials. Never expose the auth token
# through a NEXT_PUBLIC_ variable or persist it in a Docker image layer.
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
