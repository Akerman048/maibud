generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  HEAD
  EXPERT
  DESIGNER
  ARCHIVIST
  CLIENT
}

enum ProjectStatus {
  OPEN
  IN_PROGRESS
  RETURNED
  COMPLETED
  ARCHIVED
}

enum DocumentStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
  ARCHIVED
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  REVOKED
  EXPIRED
}

enum CommentThreadStatus {
  OPEN
  RESOLVED
  RETURNED
}

model User {
  id           String    @id @default(cuid())
  name         String
  email        String    @unique
  passwordHash String?
  role         UserRole  @default(DESIGNER)
  isActive     Boolean   @default(true)
  disabledAt   DateTime?

  memberships             ProjectMember[]
  organizationMemberships OrganizationMember[]
  sentInvitations         Invitation[]         @relation("InvitationSender")
  acceptedInvitations     Invitation[]         @relation("InvitationAcceptedBy")
  documents               Document[]           @relation("AuthoredDocuments")
  publishedDocuments      Document[]           @relation("PublishedDocuments")
  reviewedDocuments       Document[]           @relation("ReviewedDocuments")
  documentVersions        DocumentVersion[]
  comments                Comment[]
  createdCommentThreads   CommentThread[]      @relation("CreatedCommentThreads")
  resolvedCommentThreads  CommentThread[]      @relation("ResolvedCommentThreads")
  commentMessages         CommentMessage[]     @relation("CommentMessages")
  deletedCommentMessages  CommentMessage[]     @relation("DeletedCommentMessages")
  auditLogs               AuditLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Organization {
  id   String @id @default(cuid())
  name String

  projects    Project[]
  members     OrganizationMember[]
  invitations Invitation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Project {
  id       String        @id @default(cuid())
  name     String
  address  String
  customer String
  stage    String
  status   ProjectStatus @default(OPEN)
  deadline DateTime?

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  members     ProjectMember[]
  invitations Invitation[]
  documents   Document[]
  auditLogs   AuditLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model OrganizationMember {
  id String @id @default(cuid())

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  role UserRole

  joinedAt  DateTime  @default(now())
  removedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, userId])
  @@index([userId, role])
  @@index([organizationId, removedAt])
}

model Invitation {
  id String @id @default(cuid())

  email  String
  role   UserRole
  status InvitationStatus @default(PENDING)

  tokenHash String @unique

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  invitedById String
  invitedBy   User   @relation("InvitationSender", fields: [invitedById], references: [id], onDelete: Restrict)

  acceptedById String?
  acceptedBy   User?   @relation("InvitationAcceptedBy", fields: [acceptedById], references: [id], onDelete: SetNull)

  acceptedAt DateTime?
  revokedAt  DateTime?
  expiresAt  DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email, status])
  @@index([organizationId, status])
  @@index([expiresAt])
}

model ProjectMember {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  role UserRole

  createdAt DateTime @default(now())

  @@unique([userId, projectId])
}

model Document {
  id     String         @id @default(cuid())
  title  String
  status DocumentStatus @default(DRAFT)

  isPublishedToClient Boolean   @default(false)
  publishedAt         DateTime?
  publishedById       String?
  publishedBy         User?     @relation("PublishedDocuments", fields: [publishedById], references: [id], onDelete: SetNull)

  reviewedAt      DateTime?
  reviewedById    String?
  reviewedBy      User?     @relation("ReviewedDocuments", fields: [reviewedById], references: [id], onDelete: SetNull)
  rejectionReason String?

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  authorId String
  author   User   @relation("AuthoredDocuments", fields: [authorId], references: [id], onDelete: Cascade)

  versions       DocumentVersion[]
  comments       Comment[]
  commentThreads CommentThread[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DocumentVersion {
  id      String @id @default(cuid())
  version Int

  objectKey String  @unique
  fileName  String
  mimeType  String
  fileSize  Int
  checksum  String?

  documentId String
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  createdById String
  createdBy   User   @relation(fields: [createdById], references: [id], onDelete: Restrict)

  commentThreads CommentThread[]

  createdAt DateTime @default(now())

  @@unique([documentId, version])
  @@index([documentId, createdAt])
}

model Comment {
  id      String @id @default(cuid())
  content String

  status CommentStatus @default(OPEN)

  documentId String
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  authorId String
  author   User   @relation(fields: [authorId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CommentThread {
  id String @id @default(cuid())

  status CommentThreadStatus @default(OPEN)

  title   String?
  section String?

  documentId String
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  documentVersionId String?
  documentVersion   DocumentVersion? @relation(fields: [documentVersionId], references: [id], onDelete: SetNull)

  createdById String
  createdBy   User   @relation("CreatedCommentThreads", fields: [createdById], references: [id], onDelete: Restrict)

  resolvedById String?
  resolvedBy   User?   @relation("ResolvedCommentThreads", fields: [resolvedById], references: [id], onDelete: SetNull)

  resolvedAt DateTime?
  returnedAt DateTime?

  legacyCommentId String? @unique

  messages CommentMessage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([documentId, status, createdAt])
  @@index([documentVersionId, createdAt])
  @@index([createdById, createdAt])
}

model CommentMessage {
  id String @id @default(cuid())

  content String

  threadId String
  thread   CommentThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  authorId String
  author   User   @relation("CommentMessages", fields: [authorId], references: [id], onDelete: Restrict)

  editedAt  DateTime?
  deletedAt DateTime?

  deletedById String?
  deletedBy   User?   @relation("DeletedCommentMessages", fields: [deletedById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([threadId, createdAt])
  @@index([authorId, createdAt])
  @@index([deletedAt])
}

model AuditLog {
  id         String @id @default(cuid())
  action     String
  entityType String
  entityId   String

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
}

enum CommentStatus {
  OPEN
  RESOLVED
  RETURNED
}
